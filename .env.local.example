NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Opcional — sem ela, a busca de ISBN usa só a Open Library como fallback.
# Gere em https://console.google.com/apis/credentials, restrita à Books API.
NEXT_PUBLIC_GOOGLE_BOOKS_API_KEY=sua-chave-google-books-aqui

# Necessária para o reconhecimento de capa por IA em /scan.
# Gere em https://vercel.com/<time>/<projeto>/settings/ai-gateway (API Keys).
AI_GATEWAY_API_KEY=sua-chave-ai-gateway-aqui
